<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:minHeight="600dp">

        <!-- Logo/Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏛️"
            android:textSize="64sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-Grampanchayat"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ई-ग्रामपंचायत"
            android:textColor="#BBDEFB"
            android:textSize="18sp"
            android:layout_marginBottom="40dp"/>

        <!-- Choice Layout -->
        <LinearLayout
            android:id="@+id/layoutChoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Login Type / लॉगिन प्रकार निवडा"
                android:textColor="#BBDEFB"
                android:textSize="14sp"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- User Button -->
            <Button
                android:id="@+id/btnUserLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="👤  User Login / वापरकर्ता"
                android:textSize="16sp"
                android:textColor="@color/colorPrimary"
                android:background="@drawable/rounded_white_btn"
                android:layout_marginBottom="16dp"/>

            <!-- Admin Button -->
            <Button
                android:id="@+id/btnAdminOption"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="🔑  Admin Login / प्रशासक"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:background="@drawable/rounded_blue_btn"/>
        </LinearLayout>

        <!-- Admin Login Layout -->
        <LinearLayout
            android:id="@+id/layoutAdminLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#1A000000"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Login / प्रशासक लॉगिन"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"/>

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Username / युजरनेम"
                android:textColorHint="#BBBBBB"
                android:textColor="@color/white"
                android:background="@drawable/edittext_bg"
                android:padding="12dp"
                android:inputType="text"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Password / पासवर्ड"
                android:textColorHint="#BBBBBB"
                android:textColor="@color/white"
                android:background="@drawable/edittext_bg"
                android:padding="12dp"
                android:inputType="textPassword"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/btnAdminLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Login / लॉगिन"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:background="@drawable/rounded_accent_btn"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="← Back / परत"
                android:textColor="#BBDEFB"
                android:background="@android:color/transparent"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>