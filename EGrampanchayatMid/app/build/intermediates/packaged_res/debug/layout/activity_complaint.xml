<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/colorPrimary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="@android:color/transparent"
            android:contentDescription="Back"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Complaints / तक्रारी"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:paddingStart="4dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- User Submit Panel -->
            <LinearLayout
                android:id="@+id/userPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/card_complaint"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Submit Complaint / तक्रार नोंदवा"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#C62828"
                    android:layout_marginBottom="10dp"/>

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Your Name / तुमचे नाव *"
                    android:background="@android:color/white"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Phone Number / फोन नंबर"
                    android:background="@android:color/white"
                    android:padding="10dp"
                    android:inputType="phone"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etIssue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Describe Issue / समस्या लिहा *"
                    android:background="@android:color/white"
                    android:padding="10dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btnSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Submit / सादर करा"
                    android:backgroundTint="#C62828"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Complaints / सर्व तक्रारी"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No complaints yet.\nकोणतीही तक्रार नाही."
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/listContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
